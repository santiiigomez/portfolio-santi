{
  "entities": {
    "Message": {
      "title": "Contact Message",
      "description": "A message sent from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The sender's name." },
        "email": { "type": "string", "format": "email", "description": "The sender's email." },
        "message": { "type": "string", "description": "The message content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Score": {
      "title": "Game Score",
      "description": "A high score from the minigame.",
      "type": "object",
      "properties": {
        "playerName": { "type": "string", "description": "The player's name." },
        "score": { "type": "integer", "description": "The score achieved." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the score was achieved." }
      },
      "required": ["playerName", "score", "createdAt"]
    }
  },
  "firestore": {
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of contact messages."
    },
    "scores/{scoreId}": {
      "schema": "Score",
      "description": "Collection of game high scores."
    }
  }
}
